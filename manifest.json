{
  "manifest_version": 3,
  "name": "Adnota",
  "short_name": "Adnota",
  "version": "0.9.2",
  "description": "Annotate and edit the web. Erase, highlight, draw, and annotate any page — persistent across sessions, stored privately on your machine.",
  "author": "Adnota",
  "homepage_url": "https://adnota.app",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "*://*/*"
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "pages/*"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_popup": "popup/index.html",
    "default_title": "Adnota",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "commands": {
    "toggle-dock": {
      "suggested_key": {
        "default": "Alt+A",
        "mac": "Alt+A"
      },
      "description": "Toggle Adnota dock"
    },
    "toggle-view": {
      "suggested_key": {
        "default": "Alt+S",
        "mac": "Alt+S"
      },
      "description": "Show / hide all annotations"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "*://*/*"
      ],
      "js": [
        "lib/log.js",
        "lib/urlScopeRegistry.js",
        "lib/storage.js",
        "lib/annotationState.js",
        "lib/adnotaUI.js",
        "lib/adnotaLayout.js",
        "lib/tagIndex.js",
        "content/scratchPad.js",
        "content/dock.js",
        "content/fuzzyAnchor.js",
        "content/eraser.js",
        "content/sticky.js",
        "content/highlighter.js",
        "content/marker.js",
        "content/resizer.js",
        "content/restorer.js",
        "content/quickHighlight.js",
        "content/debugCapture.js"
      ],
      "css": [
        "lib/adnotaTokens.css",
        "lib/adnotaUI.css",
        "content/scratchPad.css",
        "content/dock.css",
        "content/sticky.css",
        "content/marker.css",
        "content/highlighter.css",
        "content/resizer.css",
        "content/quickHighlight.css"
      ],
      "run_at": "document_idle"
    }
  ]
}