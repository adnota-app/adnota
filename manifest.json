{
  "manifest_version": 3,
  "name": "Adnota",
  "version": "0.1.0",
  "description": "Annotate the web. Erase, highlight, draw, and annotate any page — persistent across sessions, stored privately on your machine.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "*://*/*"
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "pages/*"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup/index.html",
    "default_title": "Adnota"
  },
  "commands": {
    "toggle-eraser": {
      "suggested_key": {
        "default": "Alt+E",
        "mac": "Alt+E"
      },
      "description": "Toggle Eraser Mode"
    },
    "toggle-sticky": {
      "suggested_key": {
        "default": "Alt+S",
        "mac": "Alt+S"
      },
      "description": "Toggle Sticky Notes Mode"
    },
    "toggle-highlighter": {
      "suggested_key": {
        "default": "Alt+H",
        "mac": "Alt+H"
      },
      "description": "Toggle Highlighter Mode"
    },
    "toggle-view": {
      "suggested_key": {
        "default": "Alt+V",
        "mac": "Alt+V"
      },
      "description": "Toggle Annotations Visibility"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "*://*/*"
      ],
      "js": [
        "lib/storage.js",
        "lib/annotationState.js",
        "lib/vellumUI.js",
        "lib/tagIndex.js",
        "content/dock.js",
        "content/fuzzyAnchor.js",
        "content/eraser.js",
        "content/sticky.js",
        "content/highlighter.js",
        "content/marker.js",
        "content/resizer.js",
        "content/restorer.js",
        "content/quickHighlight.js"
      ],
      "css": [
        "lib/adnotaTokens.css",
        "lib/vellumUI.css",
        "content/dock.css",
        "content/sticky.css",
        "content/marker.css",
        "content/highlighter.css",
        "content/resizer.css",
        "content/quickHighlight.css"
      ],
      "run_at": "document_idle"
    }
  ]
}